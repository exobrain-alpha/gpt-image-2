# 必填。填写 Microsoft Foundry / Azure OpenAI 的资源 base endpoint。
# 示例：https://your-resource.services.ai.azure.com/
# 不要填写完整的 Target URI；代码会自动拼接 /openai/deployments/... 路径。
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/

# 必填。填写 Foundry / Azure OpenAI 中显示的 API Key。
AZURE_OPENAI_API_KEY=your-api-key

# 必填。填写模型 deployment 名称，例如 gpt-image-2。
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# 可选。当前应用默认使用 2025-04-01-preview。
# 这个值影响 Azure OpenAI REST API 的接口版本，不是模型权重版本。
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# 可选。自定义生成图片和元数据的父级目录；留空时默认使用项目根目录下的 outputs。
# 可以填写绝对路径，也可以填写相对项目根目录的路径；填写后最终会使用该路径下的 outputs。
OUTPUT_DIRECTORY=

# 可选。启用“智能提示词”功能时填写 Claude 在 Microsoft Foundry 中的部署信息。
# AZURE_CLAUDE_ENDPOINT 可填写资源 base endpoint、/anthropic base URL 或完整 Target URI。
# 示例：https://your-resource.services.ai.azure.com/anthropic/v1/messages
AZURE_CLAUDE_ENDPOINT=
AZURE_CLAUDE_API_KEY=
AZURE_CLAUDE_DEPLOYMENT_NAME=claude-opus-4-7
